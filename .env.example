# =============================================================================
# QA Dashboard - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# --- Jira Connection ---
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_USER_EMAIL=your.email@company.com
JIRA_API_TOKEN=your_jira_api_token_here
# Get token at: https://id.atlassian.com/manage-profile/security/api-tokens

# --- Field Mapping Config ---
FIELD_MAPPING_PATH=./config/field_mapping.yaml

# --- Cache Settings ---
CACHE_TTL_SECONDS=300          # 5 minutes auto-refresh
BACKGROUND_REFRESH_HOURS=5     # Full deep-refresh every 5 hours

# --- Database (Changelog storage) ---
DATABASE_URL=sqlite+aiosqlite:///./data/qa_dashboard.db
# For PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/qa_dashboard

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development        # development | production

# --- CORS (Frontend origin) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80

# --- Security (for future auth) ---
SECRET_KEY=change-this-to-a-random-secret-key-in-production
# Generate: python -c "import secrets; print(secrets.token_hex(32))"

# --- Export ---
EXPORT_MAX_ROWS=10000

# --- Jira API Limits ---
JIRA_MAX_RESULTS=100
JIRA_REQUEST_TIMEOUT=30
